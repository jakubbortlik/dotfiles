[user]
	email = jakub.bortlik@proton.me
	name = Jakub F. Bortlík
[color]
	ui = true
[core]
	editor = nvim
[diff "praat"]
	lextconv = base64
[alias]
    al = config --get-regexp alias
	b = branch
	co = checkout
	com = checkout main
	cor = checkout master
	d = diff
	dc = diff --cached
	l = log --graph --pretty=format:'%Cred%h%Creset %an: %s%Creset%C(yellow)%d%Creset %Cgreen(%cr)%Creset' --abbrev-commit --date=relative
	ll = log --oneline --graph --all --decorate
    rpo = remote prune origin
	s = status
	sb = status -sb
	sw = switch
    w = worktree
	ba = branch -a
[credential]
	helper = store
[push]
	default = simple
	autoSetupRemote = true
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[pull]
	rebase = true
[interactive]
	diffFilter = delta --color-only
[delta]
    navigate = true
    light = false
    line-numbers = true
[merge]
    conflictstyle = diff3
[diff]
    colorMoved = default
[includeIf "gitdir:~/Gitlab/"]
    path = .gitconfig.work
[init]
	defaultbranch = main
[rerere]
	enabled = true
